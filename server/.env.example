# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=itsm

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000

# API Configuration
# For development: http://localhost:8080 or http://localhost:5173
# For production: https://your-vercel-frontend.vercel.app
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Secret Key for sessions (generate a random string on production)
SECRET_KEY=your_secret_key_here_change_in_production
